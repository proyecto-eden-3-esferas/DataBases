{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "uniqueItems": true,
  "items": {
    "type": "object",
    "properties": {
      "name":        {"type": "string"},
      "synonyms":    {"type":  ["string", "array"], "items": {"type": "string"}},
      "definition":  {"type": "string"},
      "description": {"type": "string"},
      "correlations":{"type": ["string", "array"], "items": {"type": "string"}},
      "transmission":{"type": ["string", "array"], "items": {"type": "string"}},
      "infectious":  {"type": "boolean"},
      "agent":       {"type": "string", "enum": ["bacteria", "virus", "fungi", "protozoa", "worm"]},
      "causes":      {"type": ["string", "array"], "items": {"type": "string"}},
      "risk-factors":{"type": ["string", "array"], "items": {"type": "string"}},
      "symptoms":    {"type": ["string", "array"], "items": {"type": "string"}},
      "cure":        {"type": ["string", "array"],
                      "items": {
                        "type": ["string", "object"],
                        "properties" : {
                          "name":        {"type": "string"},
                          "description": {"type": "string"},
                          "discussion":  {"type": "string"}
                        }
                      }
                     }
    },
    "patternProperties": {
      "mechanism":   {"type":  ["string", "array"]},
      "types":       {"type": "array",
                      "items": {
                                 "type": "object",
                                 "properties": {
                                                 "name":        {"type": "string"},
                                                 "description": {"type": "string"}
                                               }
                               }
                     }
    },
    "anyOf": [
      {"required": ["name", "definition" ]},
      {"required": ["name", "description"]},
      {"required": ["name", "mechanism"]}
    ],
    "minProperties": 2,
    "additionalProperties": {"type": ["string", "array"], "items": {"type": ["string", "object"]}}
  }
}
